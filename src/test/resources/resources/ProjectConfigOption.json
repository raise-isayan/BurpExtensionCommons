    "bambda": {
        "http_history_display_filter":{
            "bambda":"return requestResponse.request().isInScope()\r\n && requestResponse.hasResponse()\r\n && (requestResponse.request().hasParameters(HttpParameterType.URL) || requestResponse.request().hasParameters(HttpParameterType.BODY));",
            "bambda_id":"",
            "bambda_name":""
        },
        "logger_capture_filter":{
            "bambda":"return true;",
            "bambda_id":"",
            "bambda_name":""
        },
        "logger_display_filter":{
            "bambda":"return true;",
            "bambda_id":"",
            "bambda_name":""
        },
        "sitemap_display_filter":{
            "bambda":"return node.requestResponse().request().isInScope()\n && !node.requestResponse().request().pathWithoutQuery().toLowerCase().endsWith(\".js\")\n && !node.requestResponse().request().pathWithoutQuery().toLowerCase().endsWith(\".gif\")\n && !node.requestResponse().request().pathWithoutQuery().toLowerCase().endsWith(\".jpg\")\n && !node.requestResponse().request().pathWithoutQuery().toLowerCase().endsWith(\".png\")\n && !node.requestResponse().request().pathWithoutQuery().toLowerCase().endsWith(\".css\");",
            "bambda_id":"",
            "bambda_name":""
        },
        "web_sockets_history_display_filter":{
            "bambda":"return message.upgradeRequest().isInScope()\r\n && message.direction() != Direction.CLIENT_TO_SERVER\r\n && message.direction() != Direction.SERVER_TO_CLIENT\r\n && !message.contains(Pattern.compile(\"aaa\", Pattern.DOTALL))\r\n && message.annotations().hasNotes()\r\n && message.annotations().hasHighlightColor()\r\n && message.listenerPort() == 8080;",
            "bambda_id":"",
            "bambda_name":""
        }
    },
